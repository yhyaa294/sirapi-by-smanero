# Database Configuration
DATABASE_URL=./data/sirapi.db

# Authentication
# Secret key untuk fitur login JWT (minimal 32 karakter)
JWT_SECRET=ubah-dengan-token-rahasia-yang-kuat

# Server Configuration
PORT=8080
ENVIRONMENT=development

# AI Violation Trigger Endpoint
BACKEND_URL=http://localhost:8080/api/violation

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Telegram Alerts (Guru Piket) [OPSIONAL]
# Kosongkan jika tidak menggunakan notifikasi Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
