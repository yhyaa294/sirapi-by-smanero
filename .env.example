# Telegram Bot Configuration (required by notifier.py)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Model Configuration
MODEL_PATH=models/best.pt
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45

# Camera Configuration
CAMERA_SOURCE=0
# For IP Camera: http://192.168.1.100:8080/video
# For video file: path/to/video.mp4

# Database Configuration
DATABASE_PATH=logs/detections.db

# Application Settings
DEBUG_MODE=False
LOG_LEVEL=INFO

# Optional: Email Notifications
EMAIL_ENABLED=False
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENT=supervisor@company.com

# Optional: Cloud Storage
CLOUD_STORAGE_ENABLED=False
CLOUD_PROVIDER=aws  # aws, gcp, azure
CLOUD_BUCKET=ppe-violations

# Security
API_KEY=your_api_key_here
SECRET_KEY=your_secret_key_here
